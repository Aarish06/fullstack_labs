generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model for customers/admins
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ratings ProductRating[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// Product model for e-commerce items
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  category    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations - 3NF compliance: ratings in separate table
  ratings ProductRating[]

  @@map("products")
}

// ProductRating model - separate table for likes/dislikes (3NF)
model ProductRating {
  id        String   @id @default(uuid())
  productId String
  userId    String
  isLike    Boolean // true = like, false = dislike
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One rating per user per product
  @@unique([productId, userId])
  @@map("product_ratings")
}

// Banner model for promotional banners
model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  link      String?
  isActive  Boolean  @default(true)
  position  String   @default("home") // 'home', 'category', etc.
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}